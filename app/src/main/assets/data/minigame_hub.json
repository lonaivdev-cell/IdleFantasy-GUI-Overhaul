      "runic_stone_intact":  { "display_name": "Runestone (intact)" },
      "runic_stone_crack_1": { "display_name": "Runestone (crack 1)" },
      "runic_stone_crack_2": { "display_name": "Runestone (crack 2)" },
      "runic_stone_crack_3": { "display_name": "Runestone (crack 3)" },
      "runic_fragment":      { "display_name": "Rune Fragment" }
    },
    "herblore": {
      "herblore_cauldron_empty":     { "display_name": "Cauldron (empty)" },
      "herblore_cauldron_full":      { "display_name": "Cauldron (full)" },
